# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-use-a-long-random-string-min-32-chars

# Database (Supabase — get from Settings → Database)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL_POOLER=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Frontend CORS origin
FRONTEND_URL=http://localhost:5201

# MT5 Bridge (your local .NET bridge)
MT5_BRIDGE_URL=http://localhost:5555
MT5_WEBHOOK_SECRET=change-me

# Commission Engine
ENABLE_COMMISSION_ENGINE=true
COMMISSION_SYNC_INTERVAL_MIN=15

# Portal feature flag
ENABLE_PORTAL=true
PORTAL_LOGIN_RATE_LIMIT=20

# Sync webhook — CRM sends this secret to authenticate agent-imported events
SYNC_WEBHOOK_SECRET=change-me-32-chars

# CRM API (used by crmGate to pull commission levels / products)
CRM_API_BASE_URL=
CRM_API_KEY=

# When true (default), every agent sync also pulls the agent's OWN trading
# accounts via /api/contacts/:agentId/trading-accounts and stubs them so the
# commission engine credits the agent for trades on his own accounts. Set
# to false to disable (e.g. if xdev raises a concern about CRM load).
ENABLE_AGENT_OWN_TA_FETCH=true
